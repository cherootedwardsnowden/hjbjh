# =============================================
# StrangerText - Railway Environment Variables
# =============================================
# Railway dashboard > your project > Variables tab

# REQUIRED - MongoDB connection string
# Get from: MongoDB Atlas (atlas.mongodb.com) → Connect → Drivers
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/strangertext?retryWrites=true&w=majority

# REQUIRED - Secret key for JWT tokens (any long random string)
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars

# OPTIONAL - Admin panel IP restriction (default: 176.42.131.129)
ADMIN_IP=176.42.131.129

# Auto-set by Railway - do NOT add this manually
# PORT=3000
